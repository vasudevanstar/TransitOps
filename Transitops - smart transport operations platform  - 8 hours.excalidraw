      "roundness": null,
      "seed": 262200411,
      "version": 21,
      "versionNonce": 990048873,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1783668358545,
      "link": null,
      "locked": false,
      "text": "•  Icon rail = primary app switcher; active app highlighted with left accent bar\n•  Module sidebar tree is scoped to the selected app and shows live record/alert counts (e.g. 214, 3)\n•  Breadcrumb reads App › current view/record; always reflects the active tab\n•  Global search queries across references, products, employees and policies at once\n•  Notification bell badges unread approvals, compliance alerts and mentions\n•  Avatar opens account menu: profile, company switch, log out\n•  View-tab bar lets a user jump between an app's Dashboard, List, Form and Kanban without leaving the module",
      "fontSize": 12.3,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 103.625,
      "containerId": null,
      "originalText": "•  Icon rail = primary app switcher; active app highlighted with left accent bar\n•  Module sidebar tree is scoped to the selected app and shows live record/alert counts (e.g. 214, 3)\n•  Breadcrumb reads App › current view/record; always reflects the active tab\n•  Global search queries across references, products, employees and policies at once\n•  Notification bell badges unread approvals, compliance alerts and mentions\n•  Avatar opens account menu: profile, company switch, log out\n•  View-tab bar lets a user jump between an app's Dashboard, List, Form and Kanban without leaving the module",
      "lineHeight": 1.25,
      "index": "b0F8",
      "autoResize": true
    },
