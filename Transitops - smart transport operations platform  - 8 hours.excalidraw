    {
      "id": "thidin8zqp830tw5",
      "type": "text",
      "x": 1802.4742791159279,
      "y": 948.3536613106139,
      "width": 900,
      "height": 107.625,
      "angle": 0,
      "strokeColor": "#33403a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
