    {
      "id": "uvn01d9h5iz4gq9l",
      "type": "text",
      "x": 2070,
      "y": 2212,
      "width": 1860,
      "height": 87,
      "angle": 0,
      "strokeColor": "#33403a",
      "backgroundColor": "transparent",
